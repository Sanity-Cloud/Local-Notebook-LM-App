{
  "name": "local-notebooklm-app",
  "version": "2.0.2",
  "description": "Beautiful desktop app for Local-NotebookLM PDF to Audio generation",
  "author": "Gökdeniz Gülmez <goekdenizguelmez.ml@gmail.com>",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "cross-env NODE_ENV=development electron-builder --config.productName='Local NotebookLM' --config.appId='com.localnotebooklm.app' --config.directories.buildResources=build --config.files='dist-electron/**/*' --config.files='dist/**/*' --config.mac.category='public.app-category.productivity' --config.mac.target='dir' --config.nsis.oneClick=false --config.nsis.allowToChangeInstallationDirectory=true",
    "electron:build": "tsc && vite build && electron-builder",
    "bundle-python": "node scripts/bundle-python.mjs",
    "electron:build:dmg": "npm run bundle-python && tsc && vite build && electron-builder --mac dmg",
    "electron:build:win": "npm run bundle-python && tsc && vite build && electron-builder --win nsis",
    "electron:build:linux": "npm run bundle-python && tsc && vite build && electron-builder --linux AppImage deb",
    "electron:build:all": "npm run bundle-python && tsc && vite build && electron-builder --mac dmg --win nsis --linux AppImage deb",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "lucide-react": "^0.294.0",
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.localnotebooklm.app",
    "productName": "Local NotebookLM",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist-electron/**/*",
      "dist/**/*",
      "build/**/*"
    ],
    "extraResources": [
      {
        "from": "python-runtime",
        "to": "python-runtime",
        "filter": ["**/*", "!**/__pycache__/**", "!**/*.pyc"]
      },
      {
        "from": "python-packages",
        "to": "python-packages",
        "filter": ["**/*", "!**/__pycache__/**", "!**/*.pyc", "!python-runtime/**"]
      },
      {
        "from": "local_notebooklm",
        "to": "local_notebooklm",
        "filter": ["**/*", "!**/__pycache__/**", "!**/*.pyc"]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "identity": null,
      "gatekeeperAssess": false,
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "dmg": {
      "title": "Local NotebookLM",
      "writeUpdateInfo": false
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    }
  }
}
